SUPABASE_PROJECT_ID=
SUPABASE_PUBLISHABLE_KEY=
SUPABASE_URL=
VITE_SUPABASE_PROJECT_ID=
VITE_SUPABASE_PUBLISHABLE_KEY=
VITE_SUPABASE_URL=

# Email auto-import (see scripts/gmail-oauth-setup.mjs)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REFRESH_TOKEN=
# projects/<gcp-project-id>/topics/<topic-name> — used by the daily cron to
# renew the Gmail push subscription. Omit to skip push notifications and
# rely on the daily cron alone.
GOOGLE_PUBSUB_TOPIC=
# Shared secret Vercel Cron sends as `Authorization: Bearer <value>` when it
# calls /api/import-emails. Pick any random string.
CRON_SECRET=
# Shared secret appended to the Pub/Sub push subscription's URL as
# ?secret=<value> so /api/gmail-webhook can verify the call is genuine.
GMAIL_WEBHOOK_SECRET=
# Optional: YYYY-MM-DD. Only mail after this date is ever imported; defaults
# to "today" on first run so a cold start can't backfill years of history.
EMAIL_IMPORT_START_DATE=
